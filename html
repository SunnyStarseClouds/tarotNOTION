<!DOCTYPE html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tarot Cards</title>

  <!-- Bootstrap (necessário pro collapse funcionar) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">

  <!-- Font Awesome (ícone do X) -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

  <link rel="stylesheet" href="style.css">
</head>

<body>

<div class="container py-5">

  <div class="row justify-content-center">

    <!-- CARD -->
    <div class="col-12 col-md-4 p-2">

      <div class="card-wrapper">

        <div class="card tarot-card left-card">
          <div class="card-overlay left-flip"></div>
        </div>

        <button class="btn btn-primary btn-block mt-2"
          data-toggle="collapse"
          data-target=".left-flip">
          Flip Card
        </button>

        <button class="btn btn-success btn-block"
          data-toggle="collapse"
          data-target=".left-read">
          Read
        </button>

      </div>

    </div>

  </div>

</div>

<!-- LEFT READ -->
<div class="collapse left-read overlay">
  <div class="content-box">
    <h2>Left Tarot</h2>
    <p>Coloque sua leitura aqui...</p>

    <button class="btn btn-danger"
      data-toggle="collapse"
      data-target=".left-read">
      <i class="fas fa-times"></i>
    </button>
  </div>
</div>

<!-- JS Bootstrap -->
<script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html> 
